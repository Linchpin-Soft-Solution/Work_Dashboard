generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                               String          @id @default(cuid())
  name                             String
  email                            String          @unique
  password                         String?
  role                             Role            @default(EMPLOYEE)
  designation                      String?
  baseMonthlySalary                Float           @default(0.0)
  isActive                         Boolean         @default(true)
  createdAt                        DateTime        @default(now())
  updatedAt                        DateTime        @updatedAt

  Attendance                       Attendance[]
  CalendarEvent                    CalendarEvent[]
  DailyLog                         DailyLog[]
  Invoice                          Invoice[]
  MonthlyLog                       MonthlyLog[]
  PayRecord                        PayRecord[]
  WeeklyLog                        WeeklyLog[]
  Leave                            Leave[]
  Target_Target_assignedByIdToUser Target[]        @relation("Target_assignedByIdToUser")
  Target_Target_assignedToIdToUser Target[]        @relation("Target_assignedToIdToUser")
  Prospect_assignedRep             Prospect[]      @relation("Prospect_assignedRep")
  Call                             Call[]          @relation("Call_user")
  Remark                           Remark[]        @relation("Remark_user")
  CrmActivity                      CrmActivity[]   @relation("CrmActivity_user")
}

model Attendance {
  id                  String           @id @default(cuid())
  userId              String
  date                DateTime
  checkInTime         DateTime?
  checkOutTime        DateTime?
  checkInLocation     String?
  status              AttendanceStatus @default(ABSENT)
  payMultiplier       Float            @default(1.0)
  dailyLogSubmitted   Boolean          @default(false)
  overrideReason      String?
  overriddenByAdminId String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  User User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
}

model DailyLog {
  id                 String   @id @default(cuid())
  userId             String
  date               DateTime
  content            String
  submittedByAdminId String?
  overrideReason     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  User User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
}

model WeeklyLog {
  id         String   @id @default(cuid())
  userId     String
  weekStart  DateTime
  rawSummary String?
  aiSummary  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  User User @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
}

model MonthlyLog {
  id         String   @id @default(cuid())
  userId     String
  month      DateTime
  rawSummary String?
  aiSummary  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  User User @relation(fields: [userId], references: [id])

  @@unique([userId, month])
}

model Target {
  id           String          @id @default(cuid())
  assignedById String
  assignedToId String
  title        String
  description  String?
  priority     TargetPriority  @default(MEDIUM)
  timeframe    TargetTimeframe @default(DAILY)
  dueDate      DateTime?
  status       TargetStatus    @default(PENDING)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  User_Target_assignedByIdToUser User @relation("Target_assignedByIdToUser", fields: [assignedById], references: [id])
  User_Target_assignedToIdToUser User @relation("Target_assignedToIdToUser", fields: [assignedToId], references: [id])

  @@index([status])
  @@index([assignedToId])
  @@index([dueDate])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  isPrivate     Boolean  @default(true)
  isCompanyWide Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  User User @relation(fields: [userId], references: [id])

  @@index([startTime])
  @@index([userId])
}

model Invoice {
  id              String        @id @default(cuid())
  createdById     String
  invoiceNumber   String        @unique
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientAddress   String?
  clientGstin     String?
  projectName     String?
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  
  subtotal        Int           @default(0) // Stored in paise
  gstAmount       Int           @default(0) // Stored in paise
  discountPercent Float         @default(0.0)
  discountAmount  Int           @default(0) // Stored in paise
  totalAmount     Int           @default(0) // Stored in paise
  
  notes           String?
  status          InvoiceStatus @default(DRAFT)
  isQuotation     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  User            User          @relation(fields: [createdById], references: [id])
  items           InvoiceItem[]

  @@index([status])
  @@index([createdById])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  name        String
  description String?
  category    String
  qty         Int      @default(1)
  rate        Int      // Stored in paise
  gstPercent  Float    @default(18.0)
  sortOrder   Int      @default(0)

  Invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model PayRecord {
  id            String          @id @default(cuid())
  userId        String
  month         DateTime
  baseSalary    Float
  workingDays   Int
  presentDays   Int
  lateDays      Int
  leaveDays     Int             @default(0)
  absentDays    Int             @default(0)
  calculatedPay Float
  finalPay      Float           @default(0.0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  User          User            @relation(fields: [userId], references: [id])
  PayAdjustment PayAdjustment[]

  @@unique([userId, month])
  @@index([month])
  @@index([userId])
}

model PayAdjustment {
  id               String         @id @default(cuid())
  payRecordId      String
  amount           Float
  type             AdjustmentType
  reason           String
  createdByAdminId String
  createdAt        DateTime       @default(now())

  PayRecord PayRecord @relation(fields: [payRecordId], references: [id])
}

model DailyReport {
  id          String   @id @default(cuid())
  date        DateTime @unique
  content     String
  generatedAt DateTime @default(now())
  emailSent   Boolean  @default(false)
}

model AuditLog {
  id             String   @id @default(cuid())
  adminId        String
  actionType     String
  affectedUserId String?
  details        String
  reason         String
  createdAt      DateTime @default(now())
}

enum Role {
  ADMIN
  EMPLOYEE
  INTERN
  SALES_MANAGER
  SALES_REP
}

enum CallOutcome {
  CONNECTED_INTERESTED
  CONNECTED_CALLBACK
  CONNECTED_NOT_INTERESTED
  NO_ANSWER
  UNREACHABLE
  WRONG_NUMBER
}

enum LeadSource {
  REFERRAL
  INBOUND
  COLD_LIST
  EVENT
  OTHER
}

enum CrmActivityType {
  CALL
  REMARK
  STAGE_CHANGE
  ASSIGNMENT
  FOLLOW_UP_SET
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HOLIDAY
  LEAVE
}

enum LeaveType {
  CASUAL
  SICK
  PAID
  UNPAID
  UNINFORMED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Leave {
  id           String      @id @default(cuid())
  userId       String
  startDate    DateTime
  endDate      DateTime
  type         LeaveType   @default(CASUAL)
  reason       String
  status       LeaveStatus @default(PENDING)
  managerNote  String?
  approvedById String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  User         User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum AdjustmentType {
  BONUS
  DEDUCTION
  SICK_LEAVE
  OTHER
}

enum TargetPriority {
  HIGH
  MEDIUM
  LOW
}

enum TargetStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum TargetTimeframe {
  DAILY
  WEEKLY
  MONTHLY
}

model PipelineStage {
  id        String     @id @default(cuid())
  name      String
  sortOrder Int
  isWon     Boolean    @default(false)
  isLost    Boolean    @default(false)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  Prospect Prospect[]

  @@index([sortOrder])
}

model Prospect {
  id              String       @id @default(cuid())
  companyName     String
  contactName     String
  phone           String       @unique // dedupe key
  email           String?
  city            String?
  industry        String?
  source          LeadSource   @default(OTHER)
  dealValue       Float? // INR rupees, optional
  stageId         String
  assignedRepId   String
  nextFollowUpAt  DateTime?
  lastCallOutcome CallOutcome? // denormalized for board cards
  lostReason      String?
  isInvalid       Boolean      @default(false) // wrong/invalid number
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  Stage      PipelineStage @relation(fields: [stageId], references: [id])
  Rep        User          @relation("Prospect_assignedRep", fields: [assignedRepId], references: [id])
  Calls      Call[]
  Remarks    Remark[]
  Activities CrmActivity[]

  @@index([assignedRepId])
  @@index([stageId])
  @@index([nextFollowUpAt])
}

model Call {
  id              String      @id @default(cuid())
  prospectId      String
  userId          String
  outcome         CallOutcome
  durationSeconds Int?
  remark          String?
  calledAt        DateTime    @default(now())

  Prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  User     User     @relation("Call_user", fields: [userId], references: [id])

  @@index([prospectId])
  @@index([userId])
  @@index([calledAt])
}

model Remark {
  id         String   @id @default(cuid())
  prospectId String
  userId     String
  text       String
  createdAt  DateTime @default(now())

  Prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  User     User     @relation("Remark_user", fields: [userId], references: [id])

  @@index([prospectId])
}

model CrmActivity {
  id         String          @id @default(cuid())
  prospectId String
  userId     String
  type       CrmActivityType
  detail     String
  createdAt  DateTime        @default(now())

  Prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  User     User     @relation("CrmActivity_user", fields: [userId], references: [id])

  @@index([prospectId])
  @@index([createdAt])
}
